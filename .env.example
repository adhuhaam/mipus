# Xpat Mobile API key (same as the official mobile app; set in Vercel project settings)
XPAT_API_KEY=your-api-key-here

# Telegram bot (create via @BotFather — never commit the real token)
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
# Random string; must match setWebhook secret_token
TELEGRAM_WEBHOOK_SECRET=your-random-secret

# Optional: protect POST /api/telegram/setup (register webhook without local script)
SETUP_SECRET=your-setup-secret
